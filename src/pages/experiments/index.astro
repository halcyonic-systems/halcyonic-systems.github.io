---
import BaseLayout from '../../layouts/BaseLayout.astro';

const experiments = [
  {
    title: 'Seven Windows, One Person',
    description: 'Six therapeutic frameworks and one diagnostic lens examine the same person speaking. What does each one hear? An interactive systems science exploration of how different models draw different boundaries around the same human experience.',
    href: '/experiments/seven-windows/',
    linkText: 'Enter the experience',
    icon: '◎',
    gradient: 'from-amber-500 to-orange-600',
    border: 'border-amber-100 hover:border-amber-300',
    hover: 'group-hover:text-amber-600',
    domain: 'Therapeutic Systems',
  },
];
---

<BaseLayout title="Experiments" description="Interactive explorations applying systems science to real domains">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Experiments</h1>
    <p class="mt-4 text-lg text-gray-600">
      Systems science applied to real domains. Interactive explorations you can walk through.
    </p>

    <div class="mt-10 grid gap-6">
      {experiments.map((experiment) => (
        <a
          href={experiment.href}
          class={`group card-lift p-6 rounded-xl bg-white/70 border ${experiment.border} hover:bg-white shadow-sm hover:shadow-md transition-all`}
        >
          <div class="flex gap-5">
            <div class={`w-12 h-12 shrink-0 rounded-lg bg-gradient-to-br ${experiment.gradient} flex items-center justify-center`}>
              <span class="text-white text-xl font-bold">{experiment.icon}</span>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3">
                <h3 class={`font-semibold text-gray-900 ${experiment.hover} transition-colors`}>{experiment.title}</h3>
                <span class="text-xs px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 border border-amber-200">{experiment.domain}</span>
              </div>
              <p class="mt-2 text-gray-600">{experiment.description}</p>
              <span class="mt-3 inline-block text-sm font-medium text-ocean-600">
                {experiment.linkText} <span aria-hidden="true">&rarr;</span>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
