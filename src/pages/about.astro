---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Shingai Thornton and Halcyonic Systems">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">About</h1>

    <p class="mt-8 text-lg text-gray-600">
      I'm Shingai Thornton. I've been immersed in the systems science community for five years and am defending my M.S. thesis in Systems Science at Binghamton in Spring 2026. Before that, I've been researching blockchains, cryptoeconomics, and political economy since 2012.
    </p>

    <p class="mt-4 text-lg text-gray-600">
      Halcyonic Systems is where this work comes together — tools and research applying formal systems science to these domains.
    </p>

    <div class="mt-8">
      <a
        href="mailto:shingai@halcyonic.systems"
        class="link-hover text-lg font-medium text-ocean-600 hover:text-ocean-500 transition-colors"
      >
        shingai@halcyonic.systems <span aria-hidden="true">&rarr;</span>
      </a>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200">
      <h2 class="text-sm font-medium uppercase tracking-widest text-gray-400 mb-4">Connect</h2>
      <div class="flex flex-wrap gap-6">
        <a href="https://halcyonic.discourse.group" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 hover:text-ocean-600 transition-colors">Forums</a>
        <a href="https://github.com/halcyonic-systems" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 hover:text-ocean-600 transition-colors">GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>
