---
import BaseLayout from '../layouts/BaseLayout.astro';

// Systems Technologies — warm gold
const systemsTech = [
  {
    title: 'BERT',
    description: 'An open-source framework for rigorous systems modeling across any domain. Bounded Entity Reasoning Toolkit.',
    link: 'https://bert.systems',
    linkText: 'Explore the toolkit',
  },
  {
    title: 'Facets',
    description: "Ask a question, see which facets of systems science it touches. 8-tuple dimensional classification grounded in Mobus's formal ontology.",
    link: 'https://facets.halcyonic.systems',
    linkText: 'Try the live demo',
  },
];

// Applied Science — teal
const appliedScience = [
  {
    title: 'A Deep Systems Analysis of Bitcoin',
    description: 'Bitcoin as a complex adaptive system — boundaries, flows, feedback loops, and emergent behaviors.',
    link: 'https://www.researchhub.com/paper/9310259/a-deep-systems-analysis-of-bitcoin',
    linkText: 'Read the paper',
  },
  {
    title: 'Hayekian Anticipatory Systems Explorer',
    description: "Interactive visualization of functional closure — Hayek's market theory formalized through anticipatory systems science.",
    link: 'https://halcyonic.systems/hayekian-systems/',
    linkText: 'Launch the explorer',
  },
  {
    title: 'Georgist Network Economy ABM',
    description: 'Agent-based model of land value taxation and network effects. Mesa, Railway, 450-simulation parameter sweeps.',
    link: 'https://github.com/halcyonic-systems/georgist-network-economy',
    linkText: 'View on GitHub',
  },
  {
    title: 'Seven Windows, One Person',
    description: 'Six therapeutic frameworks examine the same person speaking. What does each one hear?',
    link: '/experiments/seven-windows/',
    linkText: 'Enter the experience',
    internal: true,
  },
];

// Basic Research — ocean
const basicResearch = [
  {
    title: 'Formal Systems Ontologies',
    description: "A shared language for describing any system. Formal ontologies grounded in systems science for rigorous transdisciplinary research.",
    link: 'https://bert.gitbook.io/bert-documentation/for-researchers/system-ontology',
    linkText: 'See the foundations',
  },
  {
    title: 'The System Language Palette',
    description: 'An evolving visual vocabulary for systems science. Each icon grounded in Mobus.',
    link: '/icons',
    linkText: 'Browse the palette',
    internal: true,
  },
  {
    title: 'Halcyonic Garden',
    description: '135+ interconnected notes on systems thinking, complexity, and the patterns that connect.',
    link: 'https://garden.halcyonic.systems',
    linkText: 'Explore the garden',
  },
];

const sections = [
  { label: 'Systems Technologies', items: systemsTech, color: '#8a6a3a', tint: 'r-section-warm' },
  { label: 'Applied Science', items: appliedScience, color: '#3a6e62', tint: 'r-section-teal' },
  { label: 'Basic Research', items: basicResearch, color: '#4a7fba', tint: 'r-section-ocean' },
];
---

<BaseLayout title="Research" description="Systems science research projects and areas of focus">
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=EB+Garamond:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap');
      .r-page { --accent: #8a6a3a; --flow: #3a6e62; --ocean: #4a7fba; --ink: #1c1a16; --ink-dim: #4a4640; --ink-faint: #9a9489; --ground-border: #ddd8cf; }
      .r-title { font-family: 'Cormorant Garamond', Georgia, serif; }
      .r-body { font-family: 'EB Garamond', Georgia, serif; }
      .r-mono { font-family: 'JetBrains Mono', monospace; }

      .r-section-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      /* ── Card grid: featured first item + smaller rest ── */
      .r-card-grid {
        display: grid;
        gap: 0.6rem;
      }
      .r-card-grid.has-feature {
        grid-template-columns: 1fr 1fr;
      }
      .r-card-grid.has-feature .r-card:first-child {
        grid-column: 1 / -1;
      }
      @media (max-width: 640px) {
        .r-card-grid.has-feature { grid-template-columns: 1fr; }
      }

      .r-card {
        display: block;
        padding: 1.25rem 1.5rem;
        background: var(--card-bg);
        border-left: 2px solid var(--hover-color);
        border-radius: 0 6px 6px 0;
        text-decoration: none;
        transition: background 0.2s ease;
      }
      .r-card:hover { background: var(--card-bg-hover); }
      .r-card:hover .r-card-title { color: var(--hover-color); }

      /* Section-specific card tints */
      .r-section-warm { --card-bg: rgba(138, 106, 58, 0.06); --card-bg-hover: rgba(138, 106, 58, 0.12); }
      .r-section-teal { --card-bg: rgba(58, 110, 98, 0.06); --card-bg-hover: rgba(58, 110, 98, 0.12); }
      .r-section-ocean { --card-bg: rgba(74, 127, 186, 0.06); --card-bg-hover: rgba(74, 127, 186, 0.12); }

      /* Featured card (first in each section) */
      .r-card-grid.has-feature .r-card:first-child {
        padding: 1.75rem 2rem;
        border-left-width: 3px;
      }
      .r-card-grid.has-feature .r-card:first-child .r-card-title {
        font-size: 1.7rem;
        font-weight: 400;
      }
      .r-card-grid.has-feature .r-card:first-child .r-card-desc {
        font-size: 1.05rem;
        max-width: 700px;
      }

      .r-card-title {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.3rem;
        font-weight: 500;
        color: var(--ink);
        line-height: 1.3;
        margin-bottom: 0.3rem;
        transition: color 0.2s ease;
      }

      .r-card-desc {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 0.95rem;
        color: var(--ink-dim);
        line-height: 1.6;
        max-width: 500px;
      }

      .r-card-link {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.55rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-faint);
        margin-top: 0.5rem;
        display: inline-block;
      }

      .r-category-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.25rem;
      }
      .r-category-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .r-intro {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.1rem;
        color: var(--ink-dim);
        line-height: 1.7;
        max-width: 580px;
      }

      .r-flow-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }
      .r-flow-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.55rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .r-flow-sep {
        color: var(--ink-faint);
        font-size: 0.7rem;
      }
    </style>

  <section class="r-page mx-auto max-w-3xl px-6 py-16">
    <h1 class="r-title text-3xl font-light tracking-tight" style="color: var(--ink);">Research</h1>
    <p class="r-intro mt-4">
      We build tools grounded in formal systems science. Each technology is backed by applied research and theoretical foundations.
    </p>

    <div class="mt-6 r-flow-row">
      <span class="r-flow-label" style="color: var(--accent);">Systems Technologies</span>
      <span class="r-flow-sep">→</span>
      <span class="r-flow-label" style="color: var(--flow);">Applied Science</span>
      <span class="r-flow-sep">→</span>
      <span class="r-flow-label" style="color: var(--ocean);">Basic Research</span>
    </div>

    {sections.map((group) => (
      <div class="mt-12">
        <div class="r-category-row">
          <span class="r-category-dot" style={`background: ${group.color};`}></span>
          <span class="r-section-label" style={`color: ${group.color};`}>{group.label}</span>
        </div>
        <div class={`r-card-grid ${group.tint} ${group.items.length >= 3 ? 'has-feature' : ''}`}>
          {group.items.map((project) => (
            <a
              href={project.link}
              target={project.internal ? undefined : "_blank"}
              rel={project.internal ? undefined : "noopener noreferrer"}
              class="r-card"
              style={`--hover-color: ${group.color};`}
            >
              <div class="r-card-title">{project.title}</div>
              <div class="r-card-desc">{project.description}</div>
              <span class="r-card-link">{project.linkText}</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
