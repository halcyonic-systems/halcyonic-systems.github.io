    linkText: 'Read the paper',
    icon: '₿',
    gradient: 'from-teal-500 to-teal-600',
    border: 'border-teal-100 hover:border-teal-300',
    hover: 'group-hover:text-teal-600',
  },
  {
    title: 'Hayekian Anticipatory Systems Explorer',
    description: "An interactive visualization of Butos & McQuade's functional closure loop — Hayek's market theory formalized through anticipatory systems science. Seven domains from abstract to free banking.",
    link: 'https://halcyonic.systems/hayekian-systems/',
    linkText: 'Launch the explorer',
    icon: 'H',
    gradient: 'from-teal-500 to-teal-600',
    border: 'border-teal-100 hover:border-teal-300',
    hover: 'group-hover:text-teal-600',
  },
  {
    title: 'Georgist Network Economy ABM',
    description: 'An agent-based model exploring land value taxation and network effects in political economy. Built in Mesa, deployed on Railway, with 450-simulation parameter sweeps.',
    link: 'https://github.com/halcyonic-systems/georgist-network-economy',
    linkText: 'View on GitHub',
    icon: '⚖',
    gradient: 'from-teal-500 to-teal-600',
    border: 'border-teal-100 hover:border-teal-300',
    hover: 'group-hover:text-teal-600',
  },
  {
    title: 'Seven Windows, One Person',
    description: "Six therapeutic frameworks and one diagnostic lens examine the same person speaking. What does each one hear? An interactive systems science exploration.",
    link: '/experiments/seven-windows/',
    linkText: 'Enter the experience',
    icon: '◎',
    gradient: 'from-teal-500 to-teal-600',
    border: 'border-teal-100 hover:border-teal-300',
    hover: 'group-hover:text-teal-600',
    internal: true,
  },
];

// Systems Technologies — warm gold
const systemsTech = [
  {
    title: 'BERT',
    description: 'Curious what rigorous systems modeling looks like in practice? BERT (Bounded Entity Reasoning Toolkit) is an open-source framework I built for analyzing complex systems across any domain.',
    link: 'https://bert.systems',
    linkText: 'Explore the toolkit',
    icon: 'B',
    gradient: 'from-warm-400 to-warm-500',
    border: 'border-warm-100 hover:border-warm-300',
    hover: 'group-hover:text-warm-600',
  },
  {
    title: 'Facets',
    description: "Ask a question, see which facets of systems science it touches. Facets decomposes queries through Mobus's 8-tuple ontology, classifies them across 8 structural dimensions, and synthesizes answers grounded in formal systems theory.",
    link: 'https://facets.halcyonic.systems',
    linkText: 'Try the live demo',
    icon: '◇',
    gradient: 'from-warm-400 to-warm-500',
    border: 'border-warm-100 hover:border-warm-300',
    hover: 'group-hover:text-warm-600',
  },
];

// Hidden until more outputs to show - uncomment when ready
