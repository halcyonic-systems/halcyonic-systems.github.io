---
import BaseLayout from '../layouts/BaseLayout.astro';

// Basic Research — ocean blue
const basicResearch = [
  {
    title: 'Formal Systems Ontologies',
    description: "What if we had a shared language for describing any system? I'm developing formal ontologies grounded in systems science to make rigorous transdisciplinary research possible.",
    link: 'https://bert.gitbook.io/bert-documentation/for-researchers/system-ontology',
    linkText: 'See the foundations',
    icon: '∅',
    gradient: 'from-ocean-500 to-ocean-600',
    border: 'border-ocean-100 hover:border-ocean-300',
    hover: 'group-hover:text-ocean-600',
  },
  {
    title: 'The System Language Palette',
    description: "An evolving visual vocabulary for systems science. Click any icon to explore its theoretical foundations in Mobus.",
    link: '/icons',
    linkText: 'Browse the palette',
    icon: '◉',
    gradient: 'from-ocean-500 to-ocean-600',
    border: 'border-ocean-100 hover:border-ocean-300',
    hover: 'group-hover:text-ocean-600',
    internal: true,
  },
  {
    title: 'Halcyonic Garden',
    description: "135+ interconnected notes on systems thinking, complexity, and the patterns that connect — a digital garden of ideas from Bateson, Bunge, and beyond.",
    link: 'https://garden.halcyonic.systems',
    linkText: 'Explore the garden',
    icon: '🌿',
    gradient: 'from-ocean-500 to-ocean-600',
    border: 'border-ocean-100 hover:border-ocean-300',
    hover: 'group-hover:text-ocean-600',
  },
];

