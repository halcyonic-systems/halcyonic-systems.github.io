---

<BaseLayout title="Research" description="Systems science research projects and areas of focus">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Research</h1>
    <p class="mt-4 text-lg text-gray-600">
      We study the fundamental nature of systems and build technologies for applied transdisciplinary science.
    </p>

    <div class="mt-8 flex flex-wrap gap-3 text-sm">
      <span class="px-3 py-1 rounded-full bg-warm-50 text-warm-700 border border-warm-200">Systems Technologies</span>
      <span class="text-gray-400">→</span>
      <span class="px-3 py-1 rounded-full bg-teal-50 text-teal-700 border border-teal-200">Applied Science</span>
      <span class="text-gray-400">→</span>
      <span class="px-3 py-1 rounded-full bg-ocean-50 text-ocean-700 border border-ocean-200">Basic Research</span>
    </div>
    <p class="mt-3 text-sm text-gray-500">
      We build tools grounded in formal systems science. Each technology is backed by applied research and theoretical foundations.
    </p>

    {[
      { label: 'Systems Technologies', items: systemsTech, color: 'text-warm-500' },
      { label: 'Applied Science', items: appliedScience, color: 'text-teal-600' },
      { label: 'Basic Research', items: basicResearch, color: 'text-ocean-600' },
    ].map((group) => (
      <div class="mt-10">
        <h2 class={`text-sm font-medium uppercase tracking-widest ${group.color} mb-4`}>{group.label}</h2>
        <div class="grid gap-4">
          {group.items.map((project) => (
            <a
              href={project.link}
              target={project.internal ? undefined : "_blank"}
              rel={project.internal ? undefined : "noopener noreferrer"}
              class={`group card-lift p-6 rounded-xl bg-white border ${project.border} shadow-sm hover:shadow-md transition-all`}
            >
              <div class="flex gap-5">
                <div class={`w-12 h-12 shrink-0 rounded-lg bg-gradient-to-br ${project.gradient} flex items-center justify-center`}>
                  <span class="text-white text-xl font-bold">{project.icon}</span>
                </div>
                <div class="flex-1">
                  <h3 class={`font-semibold text-gray-900 ${project.hover} transition-colors`}>{project.title}</h3>
                  <p class="mt-2 text-gray-600">{project.description}</p>
                  <span class="mt-3 inline-block text-sm font-medium text-ocean-600">
                    {project.linkText} <span aria-hidden="true">&rarr;</span>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
