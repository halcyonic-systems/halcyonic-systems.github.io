---
import BaseLayout from '../layouts/BaseLayout.astro';
import HMark from '../components/HMark.astro';
---

<BaseLayout title="404" description="Page not found">
  <section class="fourohfour">
    <HMark size={64} variant="frost" />
    <p class="fourohfour-message">Nothing here — but the water is calm.</p>
    <a href="/" class="fourohfour-link">Return home <span aria-hidden="true">&rarr;</span></a>
  </section>
</BaseLayout>

<style>
  .fourohfour {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 6rem 2rem;
    text-align: center;
  }

  .fourohfour-message {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-frost-slate-dim);
  }

  .fourohfour-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-frost-teal);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .fourohfour-link:hover {
    opacity: 0.7;
  }
</style>
