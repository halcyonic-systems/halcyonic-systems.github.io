---
import BaseLayout from '../layouts/BaseLayout.astro';
import WalkingArrow from '../components/WalkingArrow.astro';
---

<BaseLayout title="Home" description="Systems science research and tools for transdisciplinary analysis">
  <section class="hero-section">
    <div class="hero-content">
      <WalkingArrow />
      <p class="hero-hint">click to explore</p>

      <h1 class="hero-wordmark">
        <span class="h-accent">H</span>ALCYONIC SYSTEMS
      </h1>

      <div class="hero-ctas">
        <a href="/work" class="cta-primary">
          Work <span aria-hidden="true">&rarr;</span>
        </a>
        <a href="/writing" class="cta-secondary">
          Writing <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-section {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
  }

  .hero-wordmark {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 2.2rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-frost-slate);
    margin-bottom: 0.5rem;
    opacity: 0;
    animation: fade-up 0.6s ease 1.5s forwards;
  }

  .h-accent {
    font-weight: 500;
    color: var(--color-frost-teal);
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    opacity: 0;
    animation: fade-up 0.6s ease 2.1s forwards;
  }

  .cta-primary {
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: white;
    background: var(--color-frost-teal);
    transition: opacity 0.2s ease;
    text-decoration: none;
  }

  .cta-primary:hover {
    opacity: 0.85;
  }

  .cta-secondary {
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-frost-slate);
    border: 1px solid var(--color-frost-border);
    transition: border-color 0.2s ease;
    text-decoration: none;
  }

  .cta-secondary:hover {
    border-color: var(--color-frost-teal-dim);
  }

  .hero-hint {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(30, 41, 59, 0.25);
    margin-top: -0.25rem;
    opacity: 0;
    animation: fade-up 0.5s ease 2.3s forwards;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-wordmark, .hero-ctas, .hero-hint {
      opacity: 1 !important;
      animation: none !important;
      transform: none !important;
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding: 2rem 1rem 1.5rem;
    }

    .hero-wordmark {
      font-size: 1.6rem;
      letter-spacing: 0.25em;
    }

    .hero-ctas {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
    }

    .cta-primary, .cta-secondary {
      text-align: center;
    }
  }
</style>
