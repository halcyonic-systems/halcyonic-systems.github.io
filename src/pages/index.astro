---
import BaseLayout from '../layouts/BaseLayout.astro';
import WalkingArrow from '../components/WalkingArrow.astro';
---

<BaseLayout title="Home" description="Systems science research and tools for transdisciplinary analysis">
  <section slot="hero" class="hero-zone">
    <div class="hero-content">
      <WalkingArrow />
      <p class="hero-hint">click nodes to explore &middot; hover branches for detail</p>

      <div class="hero-text">
        <h1 class="hero-wordmark">
          <span class="h-accent">H</span>ALCYONIC
        </h1>
        <p class="hero-tagline">
          Seven definitions of system. One shared structure.
        </p>
        <p class="hero-equation">
          K &cong; <strong>2</strong> &mdash; f : R &rarr; T
        </p>
      </div>

      <div class="hero-ctas">
        <a href="/work" class="cta-primary">
          Explore the Work <span aria-hidden="true">&rarr;</span>
        </a>
        <a href="/writing" class="cta-secondary">
          Read the Writing <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-16 text-center">
    <p class="text-lg leading-relaxed" style="color: var(--color-frost-slate-dim);">
      Halcyonic Systems applies formal systems science to political economy,
      cryptoeconomics, and brain-inspired computing.
    </p>
  </section>
</BaseLayout>

<style>
  .hero-zone {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 2rem 2rem;
    position: relative;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
  }

  .hero-text {
    text-align: center;
  }

  .hero-wordmark {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 2.2rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-night-parchment);
    margin-bottom: 0.5rem;
    opacity: 0;
    animation: fade-up 0.6s ease 1.5s forwards;
  }

  .h-accent {
    font-weight: 500;
    color: var(--color-night-gold);
  }

  .hero-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.25rem;
    color: rgba(226, 232, 240, 0.72);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    opacity: 0;
    animation: fade-up 0.6s ease 1.7s forwards;
  }

  .hero-equation {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: var(--color-night-gold-dim);
    letter-spacing: 0.08em;
    opacity: 0;
    animation: fade-up 0.6s ease 1.9s forwards;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    opacity: 0;
    animation: fade-up 0.6s ease 2.1s forwards;
  }

  .cta-primary {
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-night-bg);
    background: var(--color-night-gold);
    transition: opacity 0.2s ease;
    text-decoration: none;
  }

  .cta-primary:hover {
    opacity: 0.85;
  }

  .cta-secondary {
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-night-parchment);
    border: 1px solid var(--color-night-border);
    transition: border-color 0.2s ease;
    text-decoration: none;
  }

  .cta-secondary:hover {
    border-color: var(--color-night-gold-dim);
  }

  .hero-hint {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.3);
    margin-top: -0.25rem;
    opacity: 0;
    animation: fade-up 0.5s ease 2.3s forwards;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-wordmark, .hero-tagline, .hero-equation,
    .hero-ctas, .hero-hint {
      opacity: 1 !important;
      animation: none !important;
      transform: none !important;
    }
  }

  @media (max-width: 640px) {
    .hero-zone {
      padding: 2rem 1rem 1.5rem;
    }

    .hero-wordmark {
      font-size: 1.6rem;
      letter-spacing: 0.25em;
    }

    .hero-ctas {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
    }

    .cta-primary, .cta-secondary {
      text-align: center;
    }
  }
</style>
