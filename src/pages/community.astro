---
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  {
    number: '01',
    title: 'Encounter the work',
    description: "Start with the research. If it resonates, you're probably the right kind of person.",
  },
  {
    number: '02',
    title: 'Receive an invitation',
    description: 'Membership is extended to researchers, builders, and practitioners who bring something generative to the table.',
  },
  {
    number: '03',
    title: 'Claim your token',
    description: 'A single NFT on Base. Your key to private working groups, shared tools, and ongoing inquiry.',
  },
];
---

<BaseLayout title="Community" description="Forums, working groups, and research collaboration">
  <section class="mx-auto max-w-4xl px-6 py-16">

    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Community</h1>
    <p class="mt-4 text-lg text-gray-600 max-w-2xl">
      Two ways in. The forums are open to everyone. The Discord is for active contributors and collaborators.
    </p>

    <!-- Two paths -->
    <div class="mt-10 grid gap-6 sm:grid-cols-2">

      <!-- Forums -->
      <a
        href="https://halcyonic.discourse.group"
        target="_blank"
        rel="noopener noreferrer"
        class="group card-lift p-6 rounded-xl bg-white border border-gray-200 hover:border-teal-500 shadow-sm hover:shadow-md transition-all"
      >
        <div class="w-12 h-12 rounded-lg bg-teal-600 flex items-center justify-center mb-4">
          <span class="text-white text-xl">💬</span>
        </div>
        <h2 class="text-lg font-semibold text-gray-900 group-hover:text-teal-600 transition-colors">Forums</h2>
        <p class="mt-2 text-gray-600 text-sm">
          Open discussion on systems science foundations, formalization, field reports, and ongoing projects. No account required to browse.
        </p>
        <span class="mt-4 inline-block text-sm font-medium text-teal-600">
          Browse the forums <span aria-hidden="true">&rarr;</span>
        </span>
      </a>

      <!-- Discord -->
      <div class="p-6 rounded-xl bg-white border border-gray-200 shadow-sm">
        <div class="w-12 h-12 rounded-lg bg-gray-800 flex items-center justify-center mb-4">
          <span class="text-white text-xl">⬡</span>
        </div>
        <h2 class="text-lg font-semibold text-gray-900">Discord</h2>
        <p class="mt-2 text-gray-600 text-sm">
          Private working groups for active contributors. Token-gated access — hold a Halcyonic NFT to join.
        </p>
        <span class="mt-4 inline-block text-sm font-medium text-gray-400">
          Invitation only — see below
        </span>
      </div>

    </div>

    <!-- Membership flow -->
    <div class="mt-16">
      <h2 class="text-lg font-semibold text-gray-900">How Discord access works</h2>
      <p class="mt-2 text-gray-600">
        We're building a working group, not a community for spectators. Members propose projects,
        collaborate on research, and deliver reproducible work.
      </p>

      <div class="mt-8 grid gap-8 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="relative pl-4 border-l-2 border-teal-100">
            <span class="text-xs font-bold uppercase tracking-widest text-teal-500">{step.number}</span>
            <h3 class="mt-2 font-semibold text-gray-900">{step.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-12 rounded-xl bg-white border border-gray-200 p-8 text-center">
      <h2 class="text-xl font-bold text-gray-900">If the work resonates</h2>
      <p class="mt-3 max-w-lg mx-auto text-gray-600">
        We're looking for people who apply rigorous methods to hard problems —
        and want collaborators who do the same.
      </p>
      <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#"
          class="inline-flex items-center gap-2 rounded-lg bg-teal-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 transition-all"
        >
          Request an invitation <span aria-hidden="true">&rarr;</span>
        </a>
        <a
          href="/collection"
          class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-700 hover:border-teal-500 hover:text-teal-600 transition-all"
        >
          View the collection <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>

  </section>
</BaseLayout>
