---
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  {
    number: '01',
    title: 'Encounter the work',
    description: "Start with the research. If it resonates, you're probably the right kind of person.",
  },
  {
    number: '02',
    title: 'Receive an invitation',
    description: 'Membership is extended to researchers, builders, and practitioners who bring something generative to the table.',
  },
  {
    number: '03',
    title: 'Claim your token',
    description: 'A single NFT on Base. Your key to private working groups, shared tools, and ongoing inquiry.',
  },
];
---

<BaseLayout title="Community" description="A research working group applying formal systems science across domains">
  <section class="mx-auto max-w-4xl px-6 py-16">

    <!-- Identity -->
    <p class="text-sm font-medium uppercase tracking-widest text-ocean-600">Research Community</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight text-gray-900">
      We build tools and produce research. Then we work with the people who use them.
    </h1>
    <div class="mt-6 max-w-2xl space-y-4 text-lg text-gray-600">
      <p>
        Halcyonic is a working group applying formal systems science to domains that
        need it — blockchain economics, governance, network analysis, consciousness research.
        We build computational tools, publish papers, and formalize the shared language
        that makes transdisciplinary work possible.
      </p>
      <p>
        This is not a community for spectators. Members propose projects, get funded through
        <a href="https://www.researchhub.com" target="_blank" rel="noopener noreferrer" class="link-hover text-ocean-600">ResearchHub</a>,
        and deliver reproducible research. Reputation is earned through completed work.
      </p>
    </div>

    <!-- Featured Art -->
    <div class="mt-16 overflow-hidden rounded-2xl border border-gray-200 shadow-sm">
      <div class="aspect-[21/9] bg-gray-100 flex items-center justify-center">
        <!-- Replace with: <img src="/images/featured.png" alt="Halcyonic" class="w-full h-full object-cover" /> -->
        <div class="text-center">
          <span class="text-6xl select-none opacity-30">◇</span>
          <p class="mt-2 text-sm text-gray-400">Featured artwork</p>
        </div>
      </div>
    </div>

    <!-- How It Works -->
    <div class="mt-16">
      <h2 class="text-lg font-semibold text-ocean-700">How membership works</h2>
      <div class="mt-8 grid gap-8 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="relative pl-4 border-l-2 border-ocean-200">
            <span class="text-xs font-bold uppercase tracking-widest text-ocean-400">{step.number}</span>
            <h3 class="mt-2 font-semibold text-gray-900">{step.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Invitation CTA -->
    <div class="mt-16 rounded-xl bg-white border border-gray-200 p-8 text-center">
      <h2 class="text-xl font-bold text-gray-900">If the work resonates</h2>
      <p class="mt-3 max-w-lg mx-auto text-gray-600">
        We're looking for people who apply rigorous methods to hard problems —
        and want collaborators who do the same.
      </p>
      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-ocean-600 to-teal-600 px-6 py-3 text-sm font-semibold text-white shadow-sm shadow-ocean-200 hover:shadow-md hover:shadow-ocean-300 transition-all"
      >
        Request an invitation <span aria-hidden="true">&rarr;</span>
      </a>
    </div>

    <!-- Subtle collection link -->
    <p class="mt-12 text-center text-sm text-gray-400">
      <a href="/collection" class="link-hover text-gray-500 hover:text-ocean-600 transition-colors">
        View the collection <span aria-hidden="true">&rarr;</span>
      </a>
    </p>

  </section>
</BaseLayout>
