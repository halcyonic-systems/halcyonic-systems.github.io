---
---

<div class="walking-arrow">
  <svg class="arrow-svg" viewBox="0 0 700 500">
    <defs>
      <radialGradient id="node-glow-blue" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--color-night-blue)" stop-opacity="0.3"/>
        <stop offset="100%" stop-color="var(--color-night-blue)" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id="node-glow-gold" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--color-night-gold)" stop-opacity="0.3"/>
        <stop offset="100%" stop-color="var(--color-night-gold)" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <!-- Tradition ring around domain node -->
    <g class="tradition-ring" id="traditionRing">
      <circle cx="170" cy="250" r="60" fill="none" stroke="rgba(99,102,241,0.12)" stroke-width="0.5"/>
      <text class="tradition-name" x="108" y="210" transform="rotate(-30, 108, 210)">Klir</text>
      <text class="tradition-name" x="95" y="245">Bunge</text>
      <text class="tradition-name" x="100" y="280">Mobus</text>
      <text class="tradition-name" x="118" y="308" transform="rotate(20, 118, 308)">Joslyn</text>
      <text class="tradition-name" x="195" y="198" transform="rotate(30, 195, 198)">Myers</text>
      <text class="tradition-name" x="210" y="235">Wymore</text>
      <text class="tradition-name" x="195" y="305" transform="rotate(-20, 195, 305)">Mesarovi&#263;</text>
    </g>

    <!-- Node glows -->
    <circle cx="170" cy="250" r="30" fill="url(#node-glow-blue)"/>
    <circle cx="500" cy="250" r="30" fill="url(#node-glow-gold)"/>

    <!-- Arrow shaft glow -->
    <line x1="185" y1="250" x2="485" y2="250"
          stroke="var(--color-night-gold)" stroke-width="16" stroke-linecap="round" opacity="0.1"/>
    <!-- Arrow shaft -->
    <line class="shaft" x1="185" y1="250" x2="485" y2="250"
          stroke="var(--color-night-gold)" stroke-width="3.5" stroke-linecap="round" opacity="0.85"/>

    <!-- Arrowhead -->
    <polygon class="arrowhead" points="480,241 498,250 480,259" fill="#0f766e"/>

    <!-- f label -->
    <text class="f-label" x="335" y="235"
          font-family="Cormorant Garamond" font-style="italic" font-size="18"
          fill="rgba(20,184,166,0.6)" text-anchor="middle">f</text>

    <!-- Domain node -->
    <g class="node-domain" id="domainNode">
      <circle cx="170" cy="250" r="12" fill="none" stroke="var(--color-night-blue)" stroke-width="1.5"/>
      <circle class="domain-node-fill" cx="170" cy="250" r="8" fill="var(--color-night-blue)" opacity="0.8"/>
    </g>

    <!-- Codomain node -->
    <g class="node-codomain" id="codomainNode">
      <circle cx="500" cy="250" r="12" fill="none" stroke="var(--color-night-gold)" stroke-width="1.5"/>
      <circle class="codomain-node-fill" cx="500" cy="250" r="8" fill="var(--color-night-gold)" opacity="0.8"/>
    </g>

    <!-- Branches (revealed on codomain click) -->
    <g class="branch-group" id="branch-pe">
      <line class="branch-line" x1="508" y1="244" x2="600" y2="170"
            stroke="rgba(20,184,166,0.3)" stroke-width="1"/>
      <circle class="branch-dot" cx="600" cy="170" r="4" fill="rgba(20,184,166,0.5)"/>
      <rect class="branch-hit" x="570" y="140" width="120" height="60" fill="transparent"/>
      <text class="branch-label" x="612" y="168"
            font-family="Inter" font-size="10" letter-spacing="0.12em"
            fill="rgba(20,184,166,0.6)">POLITICAL ECONOMY</text>
      <text class="branch-desc" x="612" y="185"
            font-family="Cormorant Garamond" font-style="italic" font-size="12"
            fill="rgba(99,102,241,0.5)">governance, institutions, civic systems</text>
    </g>

    <g class="branch-group" id="branch-neuro">
      <line class="branch-line" x1="512" y1="250" x2="610" y2="250"
            stroke="rgba(20,184,166,0.3)" stroke-width="1"/>
      <circle class="branch-dot" cx="610" cy="250" r="4" fill="rgba(20,184,166,0.5)"/>
      <rect class="branch-hit" x="580" y="220" width="120" height="60" fill="transparent"/>
      <text class="branch-label" x="622" y="248"
            font-family="Inter" font-size="10" letter-spacing="0.12em"
            fill="rgba(20,184,166,0.6)">NEUROMORPHICS</text>
      <text class="branch-desc" x="622" y="265"
            font-family="Cormorant Garamond" font-style="italic" font-size="12"
            fill="rgba(99,102,241,0.5)">brain-inspired computing, biological systems</text>
    </g>

    <g class="branch-group" id="branch-ps">
      <line class="branch-line" x1="508" y1="256" x2="600" y2="330"
            stroke="rgba(20,184,166,0.3)" stroke-width="1"/>
      <circle class="branch-dot" cx="600" cy="330" r="4" fill="rgba(20,184,166,0.5)"/>
      <rect class="branch-hit" x="570" y="300" width="120" height="60" fill="transparent"/>
      <text class="branch-label" x="612" y="328"
            font-family="Inter" font-size="10" letter-spacing="0.12em"
            fill="rgba(20,184,166,0.6)">PROTOCOL SCIENCE</text>
      <text class="branch-desc" x="612" y="345"
            font-family="Cormorant Garamond" font-style="italic" font-size="12"
            fill="rgba(99,102,241,0.5)">coordination on commitment substrates</text>
    </g>

    <!-- Node labels -->
    <text id="label-0" x="170" y="290" text-anchor="middle"
          font-family="Cormorant Garamond" font-style="italic" font-size="16"
          fill="rgba(139,164,199,0)" style="transition: fill 0.4s ease">
      relations
    </text>
    <text id="label-1" x="500" y="290" text-anchor="middle"
          font-family="Cormorant Garamond" font-style="italic" font-size="16"
          fill="rgba(186,163,112,0)" style="transition: fill 0.4s ease">
      things
    </text>
  </svg>
</div>

<style>
  .walking-arrow {
    max-width: 700px;
    width: 100%;
    margin: 0 auto;
  }

  .arrow-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .node-domain, .node-codomain {
    cursor: pointer;
    transition: all 0.4s ease;
  }

  .node-domain:hover circle, .node-codomain:hover circle {
    r: 14;
  }

  /* Arrow draw animation */
  .shaft {
    stroke-dasharray: 280;
    stroke-dashoffset: 280;
    animation: draw-arrow 2s cubic-bezier(0.4, 0, 0.2, 1) 0.5s forwards;
  }

  @keyframes draw-arrow {
    to { stroke-dashoffset: 0; }
  }

  .arrowhead {
    opacity: 0;
    animation: fade-in 0.4s ease 2.2s forwards;
  }

  .f-label {
    opacity: 0;
    animation: fade-in 0.6s ease 2.5s forwards;
  }

  @keyframes fade-in {
    to { opacity: 1; }
  }

  /* Node pulse */
  .domain-node-fill {
    animation: pulse-node 3s ease-in-out infinite;
  }

  .codomain-node-fill {
    animation: pulse-node 3s ease-in-out infinite 1.5s;
  }

  @keyframes pulse-node {
    0%, 100% { r: 8; opacity: 0.8; }
    50% { r: 10; opacity: 1; }
  }

  /* Branch reveals */
  .branch-group {
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .branch-group.visible {
    opacity: 1;
  }

  .branch-line {
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    transition: stroke-dashoffset 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .branch-group.visible .branch-line {
    stroke-dashoffset: 0;
  }

  .branch-dot {
    opacity: 0;
    transition: opacity 0.4s ease 0.6s;
  }

  .branch-group.visible .branch-dot {
    opacity: 1;
  }

  .branch-label {
    opacity: 0;
    transition: opacity 0.4s ease 0.8s;
  }

  .branch-group.visible .branch-label {
    opacity: 1;
  }

  .branch-desc {
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .branch-hit:hover ~ .branch-desc {
    opacity: 1;
  }

  /* Tradition ring */
  .tradition-ring {
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .tradition-ring.visible {
    opacity: 1;
  }

  .tradition-name {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    letter-spacing: 0.08em;
    fill: rgba(99, 102, 241, 0.5);
  }

  /* Accessibility: respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .shaft {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }

    .arrowhead, .f-label {
      opacity: 1 !important;
      animation: none !important;
    }

    .domain-node-fill, .codomain-node-fill {
      animation: none !important;
    }

    .branch-line {
      transition: none !important;
    }

    .branch-group, .tradition-ring {
      transition-duration: 0.01s !important;
    }
  }

  /* Responsive: hide branch text on mobile */
  @media (max-width: 640px) {
    .branch-label, .branch-desc {
      display: none;
    }
  }
</style>

<script>
  const domainNode = document.getElementById('domainNode');
  const codomainNode = document.getElementById('codomainNode');
  const traditionRing = document.getElementById('traditionRing');
  const branches = ['branch-pe', 'branch-neuro', 'branch-ps'];
  const label0 = document.getElementById('label-0');
  const label1 = document.getElementById('label-1');

  let domainExpanded = false;
  let codomainExpanded = false;

  function nodeColor(node, alpha) {
    const fill = node.querySelector('.domain-node-fill, .codomain-node-fill')?.getAttribute('fill')
              || node.querySelector('circle[fill]')?.getAttribute('fill')
              || '#8ba4c7';
    const m = fill.match(/^#([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})$/i);
    if (m) return `rgba(${parseInt(m[1],16)},${parseInt(m[2],16)},${parseInt(m[3],16)},${alpha})`;
    const rm = fill.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
    if (rm) return `rgba(${rm[1]},${rm[2]},${rm[3]},${alpha})`;
    return fill;
  }

  domainNode?.addEventListener('click', () => {
    domainExpanded = !domainExpanded;
    traditionRing?.classList.toggle('visible', domainExpanded);
    if (label0) label0.style.fill = domainExpanded ? nodeColor(domainNode, 0.7) : nodeColor(domainNode, 0);
  });

  domainNode?.addEventListener('mouseenter', () => {
    if (!domainExpanded && label0) label0.style.fill = nodeColor(domainNode, 0.4);
  });
  domainNode?.addEventListener('mouseleave', () => {
    if (!domainExpanded && label0) label0.style.fill = nodeColor(domainNode, 0);
  });

  codomainNode?.addEventListener('click', () => {
    codomainExpanded = !codomainExpanded;
    branches.forEach((id, i) => {
      const el = document.getElementById(id);
      setTimeout(() => {
        el?.classList.toggle('visible', codomainExpanded);
      }, i * 150);
    });
    if (label1) label1.style.fill = codomainExpanded ? nodeColor(codomainNode, 0.7) : nodeColor(codomainNode, 0);
  });

  codomainNode?.addEventListener('mouseenter', () => {
    if (!codomainExpanded && label1) label1.style.fill = nodeColor(codomainNode, 0.4);
  });
  codomainNode?.addEventListener('mouseleave', () => {
    if (!codomainExpanded && label1) label1.style.fill = nodeColor(codomainNode, 0);
  });
</script>
