---
---

<div class="walking-arrow">
  <svg class="arrow-svg" viewBox="-20 130 740 240">
    <defs>
      <radialGradient id="node-glow-blue" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--color-frost-teal)" stop-opacity="0.15"/>
        <stop offset="100%" stop-color="var(--color-frost-teal)" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id="node-glow-gold" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--color-frost-teal)" stop-opacity="0.15"/>
        <stop offset="100%" stop-color="var(--color-frost-teal)" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <!-- Tradition ring around σ (midpoint of arrow) -->
    <g class="tradition-ring" id="traditionRing">
      <circle cx="335" cy="250" r="75" fill="none" stroke="rgba(13,148,136,0.2)" stroke-width="1" stroke-dasharray="4 3"/>
      <a href="/traditions#klir">
        <text class="tradition-name" fill="rgba(99,102,241,0.5)" x="270" y="192" transform="rotate(-20, 270, 192)">Klir</text>
      </a>
      <a href="/traditions#bunge">
        <text class="tradition-name" fill="rgba(180,83,9,0.5)" x="250" y="228">Bunge</text>
      </a>
      <a href="/traditions#mobus">
        <text class="tradition-name" fill="rgba(13,148,136,0.5)" x="265" y="290">Mobus</text>
      </a>
      <a href="/traditions#joslyn">
        <text class="tradition-name" fill="rgba(190,24,93,0.5)" x="295" y="328" transform="rotate(15, 295, 328)">Joslyn</text>
      </a>
      <a href="/traditions#myers">
        <text class="tradition-name" fill="rgba(30,41,59,0.45)" x="370" y="188" transform="rotate(20, 370, 188)">Myers</text>
      </a>
      <a href="/traditions#wymore">
        <text class="tradition-name" fill="rgba(71,85,105,0.5)" x="392" y="228">Wymore</text>
      </a>
      <a href="/traditions#mesarovic">
        <text class="tradition-name" fill="rgba(109,40,217,0.45)" x="350" y="328" transform="rotate(-15, 350, 328)">Mesarovi&#263;</text>
      </a>
    </g>

    <!-- Node glows -->
    <circle cx="170" cy="250" r="30" fill="url(#node-glow-blue)"/>
    <circle cx="500" cy="250" r="30" fill="url(#node-glow-gold)"/>

    <!-- Arrow shaft glow -->
    <line x1="185" y1="250" x2="485" y2="250"
          stroke="var(--color-frost-teal)" stroke-width="16" stroke-linecap="round" opacity="0.1"/>
    <!-- Arrow shaft -->
    <line class="shaft" x1="185" y1="250" x2="485" y2="250"
          stroke="var(--color-frost-teal)" stroke-width="3.5" stroke-linecap="round" opacity="0.85"/>

    <!-- Arrowhead -->
    <polygon class="arrowhead" points="480,241 498,250 480,259" fill="var(--color-frost-teal)"/>

    <!-- f label -->
    <text class="f-label" x="335" y="235"
          font-family="Cormorant Garamond" font-style="italic" font-size="42"
          fill="rgba(13,148,136,0.5)" text-anchor="middle">σ</text>

    <!-- Hint text -->
    <text class="sigma-hint" x="335" y="210"
          font-family="Inter" font-size="9" letter-spacing="0.15em"
          text-transform="uppercase"
          fill="rgba(13,148,136,0.4)" text-anchor="middle">click to explore</text>

    <!-- Click target for σ — must be after shaft/text to be on top -->
    <rect id="sigmaHitArea" x="285" y="215" width="100" height="70" fill="transparent" cursor="pointer"/>

    <!-- Domain branches (revealed on domain click) -->
    <g class="branch-group" id="branch-flows">
      <line class="branch-line" x1="162" y1="244" x2="70" y2="170"
            stroke="rgba(30,41,59,0.25)" stroke-width="1"/>
      <circle class="branch-dot" cx="70" cy="170" r="4" fill="rgba(30,41,59,0.4)"/>
      <rect class="branch-hit" x="-10" y="140" width="120" height="60" fill="transparent"/>
      <text class="branch-label" x="58" y="168" text-anchor="end"
            font-family="Inter" font-size="12" letter-spacing="0.1em"
            fill="rgba(30,41,59,0.5)">FLOWS</text>
      <text class="branch-desc" x="58" y="185" text-anchor="end"
            font-family="Cormorant Garamond" font-style="italic" font-size="14"
            fill="rgba(148,163,184,0.7)">matter, energy, information</text>
    </g>

    <g class="branch-group" id="branch-bonds">
      <line class="branch-line" x1="158" y1="250" x2="60" y2="250"
            stroke="rgba(30,41,59,0.25)" stroke-width="1"/>
      <circle class="branch-dot" cx="60" cy="250" r="4" fill="rgba(30,41,59,0.4)"/>
      <rect class="branch-hit" x="-10" y="220" width="120" height="60" fill="transparent"/>
      <text class="branch-label" x="48" y="248" text-anchor="end"
            font-family="Inter" font-size="12" letter-spacing="0.1em"
            fill="rgba(30,41,59,0.5)">BONDS</text>
      <text class="branch-desc" x="48" y="265" text-anchor="end"
            font-family="Cormorant Garamond" font-style="italic" font-size="14"
            fill="rgba(148,163,184,0.7)">structural connections</text>
    </g>

    <g class="branch-group" id="branch-constraints">
      <line class="branch-line" x1="162" y1="256" x2="70" y2="330"
            stroke="rgba(30,41,59,0.25)" stroke-width="1"/>
      <circle class="branch-dot" cx="70" cy="330" r="4" fill="rgba(30,41,59,0.4)"/>
      <rect class="branch-hit" x="-10" y="300" width="120" height="60" fill="transparent"/>
      <text class="branch-label" x="58" y="328" text-anchor="end"
            font-family="Inter" font-size="12" letter-spacing="0.1em"
            fill="rgba(30,41,59,0.5)">FEEDBACK</text>
      <text class="branch-desc" x="58" y="345" text-anchor="end"
            font-family="Cormorant Garamond" font-style="italic" font-size="14"
            fill="rgba(148,163,184,0.7)">circular causal structure</text>
    </g>

    <!-- Domain node -->
    <g class="node-domain" id="domainNode">
      <circle cx="170" cy="250" r="12" fill="none" stroke="var(--color-frost-slate)" stroke-width="1.5"/>
      <circle class="domain-node-fill" cx="170" cy="250" r="8" fill="var(--color-frost-slate)" opacity="0.8"/>
    </g>

    <!-- Codomain node -->
    <g class="node-codomain" id="codomainNode">
      <circle cx="500" cy="250" r="12" fill="none" stroke="var(--color-frost-teal)" stroke-width="1.5"/>
      <circle class="codomain-node-fill" cx="500" cy="250" r="8" fill="var(--color-frost-teal)" opacity="0.8"/>
    </g>

    <!-- Branches (revealed on codomain click) -->
    <g class="branch-group" id="branch-pe">
      <line class="branch-line" x1="508" y1="244" x2="600" y2="170"
            stroke="rgba(20,184,166,0.3)" stroke-width="1"/>
      <circle class="branch-dot" cx="600" cy="170" r="4" fill="rgba(20,184,166,0.5)"/>
      <rect class="branch-hit" x="570" y="140" width="120" height="60" fill="transparent"/>
      <text class="branch-label" x="612" y="168"
            font-family="Inter" font-size="12" letter-spacing="0.1em"
            fill="rgba(20,184,166,0.6)">POLITICAL ECONOMY</text>
      <text class="branch-desc" x="612" y="185"
            font-family="Cormorant Garamond" font-style="italic" font-size="14"
            fill="rgba(148,163,184,0.7)">governance, institutions, civic systems</text>
    </g>

    <g class="branch-group" id="branch-neuro">
      <line class="branch-line" x1="512" y1="250" x2="610" y2="250"
            stroke="rgba(20,184,166,0.3)" stroke-width="1"/>
      <circle class="branch-dot" cx="610" cy="250" r="4" fill="rgba(20,184,166,0.5)"/>
      <rect class="branch-hit" x="580" y="220" width="120" height="60" fill="transparent"/>
      <text class="branch-label" x="622" y="248"
            font-family="Inter" font-size="12" letter-spacing="0.1em"
            fill="rgba(20,184,166,0.6)">NEUROMORPHICS</text>
      <text class="branch-desc" x="622" y="265"
            font-family="Cormorant Garamond" font-style="italic" font-size="14"
            fill="rgba(148,163,184,0.7)">brain-inspired computing, biological systems</text>
    </g>

    <g class="branch-group" id="branch-ps">
      <line class="branch-line" x1="508" y1="256" x2="600" y2="330"
            stroke="rgba(20,184,166,0.3)" stroke-width="1"/>
      <circle class="branch-dot" cx="600" cy="330" r="4" fill="rgba(20,184,166,0.5)"/>
      <rect class="branch-hit" x="570" y="300" width="120" height="60" fill="transparent"/>
      <text class="branch-label" x="612" y="328"
            font-family="Inter" font-size="12" letter-spacing="0.1em"
            fill="rgba(20,184,166,0.6)">PROTOCOL SCIENCE</text>
      <text class="branch-desc" x="612" y="345"
            font-family="Cormorant Garamond" font-style="italic" font-size="14"
            fill="rgba(148,163,184,0.7)">coordination on commitment substrates</text>
    </g>

    <!-- Node labels -->
    <text id="label-0" x="170" y="295" text-anchor="middle"
          font-family="Cormorant Garamond" font-style="italic" font-size="20"
          fill="rgba(30,41,59,0)" style="transition: fill 0.4s ease">
      relations
    </text>
    <text id="label-1" x="500" y="295" text-anchor="middle"
          font-family="Cormorant Garamond" font-style="italic" font-size="20"
          fill="rgba(13,148,136,0)" style="transition: fill 0.4s ease">
      things
    </text>
  </svg>
</div>

<style>
  .walking-arrow {
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
  }

  .arrow-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .node-domain, .node-codomain {
    cursor: pointer;
    transition: all 0.4s ease;
  }

  .node-domain:hover circle, .node-codomain:hover circle {
    r: 14;
  }

  /* Arrow draw animation */
  .shaft {
    stroke-dasharray: 280;
    stroke-dashoffset: 280;
    animation: draw-arrow 1.4s cubic-bezier(0.4, 0, 0.2, 1) 0.3s forwards;
  }

  @keyframes draw-arrow {
    to { stroke-dashoffset: 0; }
  }

  .arrowhead {
    opacity: 0;
    animation: fade-in 0.4s ease 1.5s forwards;
  }

  .f-label {
    opacity: 0;
    animation: fade-in 0.5s ease 1.3s forwards;
  }

  .sigma-hint {
    opacity: 0;
    animation: fade-in 0.5s ease 1.6s forwards;
  }

  @keyframes fade-in {
    to { opacity: 1; }
  }

  /* Node pulse */
  .domain-node-fill {
    animation: pulse-node 3s ease-in-out infinite;
  }

  .codomain-node-fill {
    animation: pulse-node 3s ease-in-out infinite 1.5s;
  }

  @keyframes pulse-node {
    0%, 100% { r: 8; opacity: 0.8; }
    50% { r: 10; opacity: 1; }
  }

  /* Branch reveals */
  .branch-group {
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .branch-group.visible {
    opacity: 1;
  }

  .branch-line {
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    transition: stroke-dashoffset 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .branch-group.visible .branch-line {
    stroke-dashoffset: 0;
  }

  .branch-dot {
    opacity: 0;
    transition: opacity 0.4s ease 0.6s;
  }

  .branch-group.visible .branch-dot {
    opacity: 1;
  }

  .branch-label {
    opacity: 0;
    transition: opacity 0.4s ease 0.8s;
  }

  .branch-group.visible .branch-label {
    opacity: 1;
  }

  .branch-desc {
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .branch-hit:hover ~ .branch-desc {
    opacity: 1;
  }

  /* Tradition ring */
  .tradition-ring {
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .tradition-ring.visible {
    opacity: 1;
  }

  .tradition-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-style: italic;
    cursor: pointer;
    transition: fill 0.2s ease;
  }

  .tradition-ring a:hover .tradition-name {
    fill: var(--color-frost-teal);
  }

  /* Accessibility: respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .shaft {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }

    .arrowhead, .f-label {
      opacity: 1 !important;
      animation: none !important;
    }

    .domain-node-fill, .codomain-node-fill {
      animation: none !important;
    }

    .branch-line {
      transition: none !important;
    }

    .branch-group, .tradition-ring {
      transition-duration: 0.01s !important;
    }
  }

  /* Responsive: hide branch text on mobile */
  @media (max-width: 640px) {
    .branch-label, .branch-desc {
      display: none;
    }
  }
</style>

<script>
  const domainNode = document.getElementById('domainNode');
  const codomainNode = document.getElementById('codomainNode');
  const sigmaHit = document.getElementById('sigmaHitArea');
  const traditionRing = document.getElementById('traditionRing');
  const branches = ['branch-pe', 'branch-neuro', 'branch-ps'];
  const label0 = document.getElementById('label-0');
  const label1 = document.getElementById('label-1');

  let sigmaExpanded = false;
  let codomainExpanded = false;

  function nodeColor(node, alpha) {
    const fill = node.querySelector('.domain-node-fill, .codomain-node-fill')?.getAttribute('fill')
              || node.querySelector('circle[fill]')?.getAttribute('fill')
              || '#8ba4c7';
    const m = fill.match(/^#([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})$/i);
    if (m) return `rgba(${parseInt(m[1],16)},${parseInt(m[2],16)},${parseInt(m[3],16)},${alpha})`;
    const rm = fill.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
    if (rm) return `rgba(${rm[1]},${rm[2]},${rm[3]},${alpha})`;
    return fill;
  }

  // Clicking σ reveals tradition ring
  sigmaHit?.addEventListener('click', () => {
    sigmaExpanded = !sigmaExpanded;
    traditionRing?.classList.toggle('visible', sigmaExpanded);
  });

  // Domain node reveals "relations" label + relation branches
  let domainExpanded = false;
  const domainBranches = ['branch-flows', 'branch-bonds', 'branch-constraints'];

  domainNode?.addEventListener('click', () => {
    domainExpanded = !domainExpanded;
    if (label0) label0.style.fill = domainExpanded ? 'rgba(30,41,59,0.6)' : 'rgba(30,41,59,0)';
    domainBranches.forEach((id, i) => {
      const el = document.getElementById(id);
      setTimeout(() => {
        el?.classList.toggle('visible', domainExpanded);
      }, i * 150);
    });
  });

  domainNode?.addEventListener('mouseenter', () => {
    if (!domainExpanded && label0) label0.style.fill = 'rgba(30,41,59,0.3)';
  });
  domainNode?.addEventListener('mouseleave', () => {
    if (!domainExpanded && label0) label0.style.fill = domainExpanded ? 'rgba(30,41,59,0.6)' : 'rgba(30,41,59,0)';
  });

  // Codomain node reveals branches + "things" label
  codomainNode?.addEventListener('click', () => {
    codomainExpanded = !codomainExpanded;
    branches.forEach((id, i) => {
      const el = document.getElementById(id);
      setTimeout(() => {
        el?.classList.toggle('visible', codomainExpanded);
      }, i * 150);
    });
    if (label1) label1.style.fill = codomainExpanded ? 'rgba(13,148,136,0.6)' : 'rgba(13,148,136,0)';
  });

  codomainNode?.addEventListener('mouseenter', () => {
    if (!codomainExpanded && label1) label1.style.fill = 'rgba(13,148,136,0.3)';
  });
  codomainNode?.addEventListener('mouseleave', () => {
    if (!codomainExpanded && label1) label1.style.fill = codomainExpanded ? 'rgba(13,148,136,0.6)' : 'rgba(13,148,136,0)';
  });
</script>
