---
import HMark from './HMark.astro';

const navItems = [
  { href: '/work', label: 'Work' },
  { href: '/writing', label: 'Writing' },
  { href: '/about', label: 'About' },
];
---

<header class="sticky top-0 z-50" style="background: var(--color-frost-bg); border-bottom: 1px solid var(--color-frost-border);">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center gap-3 group">
      <HMark size={40} variant="frost" />
      <span class="text-base sm:text-lg font-semibold" style="color: var(--color-frost-slate);">
        <span class="hidden sm:inline md:hidden">Halcyonic</span>
        <span class="hidden md:inline">Halcyonic Systems</span>
      </span>
    </a>
    <ul class="flex items-center gap-3 sm:gap-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="link-hover text-sm sm:text-base font-medium transition-colors"
            style="color: rgba(30, 41, 59, 0.75);"
            onmouseover="this.style.color='var(--color-frost-teal)'"
            onmouseout="this.style.color='rgba(30, 41, 59, 0.75)'"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
