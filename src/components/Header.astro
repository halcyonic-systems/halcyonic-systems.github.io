---
import HMark from './HMark.astro';

const navItems = [
  { href: '/work', label: 'Work' },
  { href: '/writing', label: 'Writing' },
  { href: '/about', label: 'About' },
];
---

<header id="site-header" class="sticky top-0 z-50 transition-colors duration-300">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center gap-3 group">
      <HMark size={32} variant="night" class="h-mark-night" />
      <HMark size={32} variant="frost" class="h-mark-frost hidden" />
      <span class="nav-wordmark text-base sm:text-lg font-semibold transition-colors">
        <span class="hidden sm:inline md:hidden">Halcyonic</span>
        <span class="hidden md:inline">Halcyonic Systems</span>
      </span>
    </a>
    <ul class="flex items-center gap-3 sm:gap-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="link-hover nav-link text-sm sm:text-base font-medium transition-colors"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  header.in-hero {
    background: transparent;
    border-bottom-color: var(--color-night-border);
  }

  header.in-hero .nav-wordmark {
    color: var(--color-night-parchment);
  }

  header.in-hero .nav-link {
    color: var(--color-night-parchment-dim);
  }

  header.in-hero .nav-link:hover {
    color: var(--color-night-parchment);
  }

  header.scrolled {
    background: var(--color-frost-bg);
    border-bottom-color: var(--color-frost-border);
  }

  header.scrolled .nav-wordmark {
    color: var(--color-frost-slate);
  }

  header.scrolled .nav-link {
    color: var(--color-frost-slate-dim);
  }

  header.scrolled .nav-link:hover {
    color: var(--color-frost-teal);
  }

  header.scrolled .h-mark-night {
    display: none;
  }

  header.scrolled .h-mark-frost {
    display: inline;
  }

  /* Default (no hero) — frost bg */
  header.no-hero {
    background: var(--color-frost-bg);
    border-bottom-color: var(--color-frost-border);
  }

  header.no-hero .nav-wordmark {
    color: var(--color-frost-slate);
  }

  header.no-hero .nav-link {
    color: var(--color-frost-slate-dim);
  }

  header.no-hero .nav-link:hover {
    color: var(--color-frost-teal);
  }

  header.no-hero .h-mark-night {
    display: none;
  }

  header.no-hero .h-mark-frost {
    display: inline;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const heroZone = document.querySelector('.hero-zone');

  if (heroZone && header) {
    header.classList.add('in-hero');

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          header.classList.add('in-hero');
          header.classList.remove('scrolled');
        } else {
          header.classList.remove('in-hero');
          header.classList.add('scrolled');
        }
      },
      { threshold: 0, rootMargin: '-48px 0px 0px 0px' }
    );

    observer.observe(heroZone);
  } else if (header) {
    header.classList.add('no-hero');
  }
</script>
