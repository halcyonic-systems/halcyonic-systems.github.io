---
const currentYear = new Date().getFullYear();
---

<footer class="border-t mt-auto" style="border-color: var(--color-frost-border); background: var(--color-frost-bg);">
  <div class="mx-auto max-w-4xl px-6 py-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm" style="color: var(--color-frost-slate-dim);">
        &copy; {currentYear} Halcyonic Systems
      </p>
      <div class="flex items-center gap-6">
        <a
          href="mailto:shingai@halcyonic.systems"
          class="text-sm transition-colors"
          style="color: var(--color-frost-slate-dim);"
        >
          Contact
        </a>
        <a
          href="https://github.com/halcyonic-systems"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm transition-colors"
          style="color: var(--color-frost-slate-dim);"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</footer>
